generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma-bot"
}

datasource db {
  provider = "postgresql"
}

model Bot {
  id        String     @id @default(cuid())
  name      String
  apiKey    String     @unique
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  orders    BotOrder[]
}

model BotOrder {
  id         String   @id @default(cuid())
  botId      String
  externalId String?
  tradeId    String?
  type       String
  symbol     String
  amount     Float
  price      Float
  fillPrice  Float?
  fillAmount Float?
  status     String   @default("pending")
  createdAt  DateTime @default(now())
  bot        Bot      @relation(fields: [botId], references: [id])
}
